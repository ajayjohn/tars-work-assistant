{
  "$schema": "https://claude.ai/schemas/plugin-hooks.schema.json",
  "_comment": "TARS v3.2.1 plugin-level hook wiring. Claude Code plugins load hooks from hooks/hooks.json. Matchers are intentionally narrow so the hooks fire only on TARS-relevant tool calls. All paths quote ${CLAUDE_PLUGIN_ROOT} to handle spaces in directory names (e.g. Application Support).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\""}
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions-loaded.py\""}
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*|Bash",
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.py\""}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__tars_vault__.*|Bash",
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.py\""}
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.py\""}
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end.py\""}
        ]
      }
    ]
  }
}
